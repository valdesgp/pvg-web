
<%- include('head.ejs') %>

<script>
$(document).ready(function() {
  // Toggle menu on button click
  $('#menu-btn').click(function(e) {
    e.stopPropagation(); // Prevent the click event from bubbling up to document
    $('#menu-dropbar').toggleClass('mobile-navbar-hide'); // Toggle visibility of the sidebar
  });

  // Close the menu if you click outside of it
  $(document).click(function(e) {
    if (!$(e.target).closest('#menu-dropbar').length && !$(e.target).closest('#menu-btn').length) {
      $('#menu-dropbar').addClass('mobile-navbar-hide'); // Close the menu
    }
  });

  // Prevent the sidebar from closing when clicked inside it
  $('#menu-dropbar').click(function(e) {
    e.stopPropagation(); // Prevent event from bubbling up to the document
  });
});

  
</script>



            