<%- include('head.ejs') %>

<!-- Mobile Menu Toggle Script -->
<script>
  $(document).ready(function () {
    // Toggle mobile sidebar on hamburger button click
    $('#menu-btn').click(function (e) {
      e.stopPropagation();
      $('#menu-dropbar').toggleClass('mobile-navbar-hide');
    });

    // Close sidebar when clicking anywhere outside of it
    $(document).click(function (e) {
      if (!$(e.target).closest('#menu-dropbar').length && !$(e.target).closest('#menu-btn').length) {
        $('#menu-dropbar').addClass('mobile-navbar-hide');
      }
    });

    // Prevent the sidebar from closing when clicking inside it
    $('#menu-dropbar').click(function (e) {
      e.stopPropagation();
    });
  });
</script>
