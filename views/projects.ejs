<div class="flex mb-10"> 
<p class="text-sms font-normal mx-3 mt-2">
    The content below are case studies and samples embedded from my Behance portfolio and highlight my UX/UI design and Web Development process, from research and wireframing to high-fidelity prototypes and final solutions.
</p>
</div>

                  <!-- Bottom Border -->
                  <th class="rounded-t-xl">
                    <div class="lg:flex hidden items-center justify-between mb-2 -mr-5 lg:mr-0 border-b select-none"></div>
                  </th>

  

<div class="flex items-center justify-between px-4 -mt-3 -mb-1">
  <div class="font-normal text-xl flex mb-1 items-center space-x-3">
    <span>
      Displaying <%= perPage %> results per page 
      <span class=" text-xl">(Total Projects: <%= count %>)</span>
    </span>
  </div>

  <form method="GET" action="/projects" class="flex mr-1 items-center space-x-2">
    <input type="hidden" name="page" value="1" />
    <label for="perPage" class="text-lg font-light text-gray-700">Show:</label>
    <select id="perPage" name="perPage"
            class="border border-gray-300 rounded-md px-2 py-1 text-lg font-light focus:outline-none focus:ring-2 focus:ring-blue-200"
            onchange="this.form.submit()">
      <option value="4" <%= perPage == 4 ? 'selected' : '' %>>4</option>
      <option value="6" <%= perPage == 6 ? 'selected' : '' %>>6</option>
      <option value="8" <%= perPage == 8 ? 'selected' : '' %>>8</option>
      <option value="all" <%= perPage === 'all' ? 'selected' : '' %>>All</option>
    </select>
  </form>
</div>



                <div class="flex items-center justify-between border-b select-none mb-2">
                </div>

              <%- include('pagination-featured.ejs') %>

              
            </div>
<div class="flex justify-center mt-6 items-center space-x-2">
  <a href="/projects?page=<%= current > 1 ? current - 1 : 1 %>&perPage=<%= perPage %>" 
     class="px-3 py-2 rounded-md gallery-box-shadow">Prev</a>

  <% for(let i = 1; i <= pages; i++) { %>
    <a href="/projects?page=<%= i %>&perPage=<%= perPage %>" 
       class="px-4 py-2 gallery-box-shadow rounded-md font-medium <%= i === current ? 'bg-black gallery-box-shadow bg-opacity-75 text-white' : 'border-black border-opacity-25' %>">
      <%= i %>
    </a>
  <% } %>

  <a href="/projects?page=<%= current < pages ? current + 1 : pages %>&perPage=<%= perPage %>" 
     class="px-3 py-2 gallery-box-shadow rounded-md">Next</a>
</div>

