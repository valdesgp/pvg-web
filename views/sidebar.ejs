<!-- Year slide toggle script -->
<script>
  function showSlide(year) {
    // Hide all year slides
    const slides = document.querySelectorAll('.slide');
    slides.forEach(slide => slide.classList.add('hidden'));

    // Show the selected year slide
    document.getElementById(`slide-${year}`).classList.remove('hidden');

    // Remove active state from all year buttons
    const buttons = document.querySelectorAll('.year-button');
    buttons.forEach(button => button.classList.remove('active'));

    // Set active state on the clicked button
    document.querySelector(`.year-button[onclick="showSlide('${year}')"]`).classList.add('active');
  }
</script>
